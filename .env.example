# ---------------------------------------------------------------------------
# Sigil Social Scraper - environment configuration
# Copy to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# Apify API token (https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Postgres connection string - use the SESSION POOLER string
# (Supabase Dashboard -> Project Settings -> Database -> Connection string ->
#  "Session pooler"). Must be the SQLAlchemy asyncpg URL form:
#   postgresql+asyncpg://postgres.<ref>:<password>@<host>:5432/postgres
# Do NOT route bulk writes through PostgREST / supabase-py.
SUPABASE_DB_URL=postgresql+asyncpg://postgres.gdeqeahbzdqeijtizxvw:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# Orchestration tuning ------------------------------------------------------
# Max number of Apify actor runs allowed in-flight at once.
MAX_CONCURRENT_RUNS=4
# Hard daily spend guard. Runner refuses to start runs that would exceed this.
DAILY_BUDGET_USD=50.0
# How often the runner starts new due campaigns (seconds).
RUNNER_INTERVAL_SECS=900
# How often the collector polls running runs (seconds). Should be << runner.
COLLECTOR_INTERVAL_SECS=60
# Per-run results cap fed to each actor (core throughput / cost lever).
RESULTS_LIMIT_PER_RUN=1000
# Hard cap a single actor run can return; runs split when the per-run limit
# exceeds this (keeps us to "few large runs" rather than many small ones).
ACTOR_MAX_RESULTS_PER_RUN=5000
# Rough pre-run cost estimate (USD/run) used only by the daily budget guard.
EST_COST_PER_RUN_USD=1.0
# Max retry attempts for a failed run before the campaign is given up for the day.
MAX_RUN_RETRIES=3

# Logging -------------------------------------------------------------------
LOG_LEVEL=INFO

# Path to the campaigns definition file.
CAMPAIGNS_FILE=campaigns.yaml

# Per-platform Apify actor overrides (defaults shown). Override if you fork an
# actor or the slug changes - confirm exact slugs in the Apify console.
TIKTOK_ACTOR_ID=clockworks/tiktok-scraper
INSTAGRAM_ACTOR_ID=apify/instagram-scraper
FACEBOOK_ACTOR_ID=apify/facebook-posts-scraper

# Optional: local Postgres URL used ONLY by the repository dedup test.
# If unset, that test is skipped. Plain asyncpg form (no +asyncpg needed but ok):
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scraper_test
